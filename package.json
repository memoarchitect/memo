{
  "name": "@memoarchitect/ontology",
  "version": "0.4.6",
  "packageManager": "pnpm@9.15.0",
  "description": "MEMO — Medical Engineering Modelling Ontology. Pure SysML v2 medical-device ontology with native constraints, portable to any conformant SysML v2 tool (SysIDE, SysON, sysand).",
  "scripts": {
    "build": "bash scripts/build-kpar.sh",
    "check": "bash scripts/build-kpar.sh",
    "test": "node --test test/package.test.mjs",
    "docs:serve": "python3 -m mkdocs serve",
    "docs:build": "python3 -m mkdocs build --strict"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "keywords": [
    "sysml-v2",
    "kerml",
    "medical-device",
    "iso-14971",
    "iec-62304",
    "ontology",
    "mbse"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoarchitect/memo.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./package.json": "./package.json",
    "./manifest": "./memo.manifest.yaml",
    "./src/*": "./src/*",
    "./profile/*": "./profile/*",
    "./methodologies/*": "./methodologies/*",
    "./templates/*": "./template/*",
    "./examples/*": "./examples/*"
  },
  "files": [
    "README.md",
    "LICENSE",
    "memo.manifest.yaml",
    "ontology/memo.package.yaml",
    "ontology/memo.rendering.yaml",
    "profile/memo.package.yaml",
    "profile/archetypes.yaml",
    "profile/templates/",
    "methodologies/default/memo.package.yaml",
    "methodologies/gpca/memo.package.yaml",
    "src/architecture/",
    "src/artifacts/",
    "src/compliance/",
    "src/core/",
    "src/methodology/*.sysml",
    "src/methodology/LICENSES/",
    "src/rules/",
    "src/viewpoints/",
    "src/medical_device_library.sysml",
    "src/memo_namespaces.sysml",
    "template/",
    "examples/"
  ]
}
